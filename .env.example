# Copy this file to .env and fill in real values
DATABASE_URL=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_BASE_URL=https://api.safaricom.co.ke
MPESA_CONFIRMATION_URL=
MPESA_VALIDATION_URL=
MPESA_TEST_MSISDN=254712345679
MPESA_TEST_AMOUNT=100
SECRET_KEY=

# Phone hashing notes:
# - Customer phones are hashed with SHA-256 for M-Pesa payment matching
# - Safaricom sends the hashed MSISDN (SHA-256) in callbacks
# - When a customer registers, phone_hash = SHA-256(customer.phone)
# - Incoming callback MSISDN_hash matches customer.phone_hash for secure lookup
